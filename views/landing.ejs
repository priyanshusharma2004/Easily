<%- include('layouts/header') %>

<section class="hero">
  <div class="hero-content">
    <h1>Find Your Dream Job with <span class="brand">Easily</span></h1>
    <p>Connect with top companies. Apply in seconds. Get hired faster.</p>
    <div class="hero-btns">
      <a href="/jobs" class="btn btn-primary btn-lg">Browse Jobs</a>
      <a href="/register" class="btn btn-outline btn-lg">Post a Job</a>
    </div>
  </div>
  <div class="hero-stats">
    <div class="stat-card"><span class="stat-num">500+</span><span>Jobs Posted</span></div>
    <div class="stat-card"><span class="stat-num">200+</span><span>Companies</span></div>
    <div class="stat-card"><span class="stat-num">1000+</span><span>Applicants</span></div>
  </div>
</section>

<section class="features">
  <div class="feature-card">
    <div class="feature-icon">🔍</div>
    <h3>Search Jobs</h3>
    <p>Filter by role, category, or location to find your perfect match.</p>
  </div>
  <div class="feature-card">
    <div class="feature-icon">📄</div>
    <h3>Easy Apply</h3>
    <p>Apply with your resume in just a few clicks.</p>
  </div>
  <div class="feature-card">
    <div class="feature-icon">🏢</div>
    <h3>For Recruiters</h3>
    <p>Post, manage, and track job listings with ease.</p>
  </div>
</section>

<%- include('layouts/footer') %>
